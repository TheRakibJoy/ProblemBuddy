# Copy to .env for local development. Never commit .env.
DJANGO_SETTINGS_MODULE=ProblemBuddy.settings.dev

# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-in-dev-and-prod

DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database — leave blank to use SQLite in dev.
# Example Postgres: postgres://user:pass@localhost:5432/problembuddy
DATABASE_URL=

# Cache — leave blank for LocMem in dev.
# Example Redis: redis://localhost:6379/1
REDIS_URL=

# HTTPS / security (prod only)
DJANGO_SECURE_SSL_REDIRECT=False
